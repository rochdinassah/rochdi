#!/usr/bin/env node

const rochdi = require('../main');

const { Logger, HttpClient } = rochdi;

const logger = new Logger({ prefix: 'interaction' });
const http_client = new HttpClient({ logger });

const { HOST_ADDR, HOST_PORT } = process.env;

const base_url = 'http://'+HOST_ADDR+':'+HOST_PORT;

startTimer('GetInteraction');

http_client.get(base_url+'/GetInteraction').then(res => {
  const { status_code, data } = res;

  data.took = endTimer('GetInteraction');

  log(data);
});
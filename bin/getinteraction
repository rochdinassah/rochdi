#!/usr/bin/env node

const rochdi = require('../main');

const { Logger, HttpClient } = rochdi;

const logger = new Logger({ prefix: 'interaction' });
const http_client = new HttpClient({ logger });

const { REMOTE_ADDR, REMOTE_PORT } = process.env;

const address = 'http://'+REMOTE_ADDR+':'+REMOTE_PORT;

http_client.get(address+'/GetInteraction').then(res => {
  log(res.data);
});
#!/bin/bash

dir=$(pwd)
list=$(npm version)

[[ $list =~ rochdi:" "\'([0-9]).([0-9]).([0-9]+)\' ]]

major=${BASH_REMATCH[1]}
minor=${BASH_REMATCH[2]}
patch=${BASH_REMATCH[3]}

echo current version: $major.$minor.$patch

patch=$((1+$patch))

git add -A
git commit -m AUTO_COMMIT &> /dev/null

echo commit ok

npm version $major.$minor.$patch &> /dev/null

echo new version ok: $major.$minor.$patch

git push &> /dev/null

echo push ok

npm publish &> /dev/null

echo publish complete